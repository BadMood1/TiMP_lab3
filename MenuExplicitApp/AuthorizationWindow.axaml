<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="260"
        x:Class="MenuExplicitApp.AuthorizationWindow"
        Title="Авторизация" CanResize="False" Background="#D9E8F8" Padding="0" Foreground="Black">
    <Border CornerRadius="8" Background="#E7EFFB" Margin="10" Padding="0">
        <StackPanel>
            <Border Background="#FFD639" Height="72" CornerRadius="8,8,0,0" Padding="10" HorizontalAlignment="Stretch">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch">
                    <TextBlock Text="АИС Отдел кадров" FontSize="20" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="Black" />
                    <TextBlock Text="Версия 1.0.0.0" FontSize="12" HorizontalAlignment="Right" Margin="0,2,8,0" Foreground="Black" />
                </StackPanel>
            </Border>

            <TextBlock Text="Введите имя пользователя и пароль" Margin="16,10,16,0" FontSize="14" Foreground="Black" />

            <Border Background="White" CornerRadius="6" Margin="16" Padding="12" BorderBrush="#B0C9E6" BorderThickness="1">
                <StackPanel Spacing="10">
                    <TextBlock Text="Имя пользователя" />
                    <TextBox x:Name="UsernameTextBox" MinHeight="32" />

                    <TextBlock Text="Пароль" />
                    <TextBox x:Name="PasswordTextBox" MinHeight="32" PasswordChar="*" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,0,16,0" Spacing="8">
                <Button Content="Отмена" Width="96" Click="OnCancelClicked" />
                <Button Content="Войти" Width="96" Background="#1C6BE8" Foreground="White" Click="OnLoginClicked" />
            </StackPanel>

            <TextBlock x:Name="ErrorTextBlock" Foreground="Red" Margin="16,10,16,0" TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</Window>
